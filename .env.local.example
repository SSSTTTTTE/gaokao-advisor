DEEPSEEK_API_KEY=xxxxxxx
DEEPSEEK_MODEL=deepseek-chat

# Optional fallbacks. Official Suzhou University/Jiangsu score parsing does not require Tavily.
TAVILY_API_KEY=

# Optional adapter for iefnaf/mcp-gaokao rank lookups.
# The app exposes lookupRankByScore and calls this endpoint when configured.
MCP_GAOKAO_RANK_ENDPOINT=

# Optional lifefloating/gaokao-vault PostgreSQL data source.
# It is tried before search fallbacks for schools, admission scores, and score-to-rank.
GAOKAO_VAULT_DATABASE_URL=
# GAOKAO_DB__DSN is also accepted when sharing env with gaokao-vault itself.
GAOKAO_DB__DSN=
