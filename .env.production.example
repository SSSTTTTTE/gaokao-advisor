DEEPSEEK_API_KEY=replace-with-your-deepseek-key
DEEPSEEK_MODEL=deepseek-chat

# Optional fallback web search.
TAVILY_API_KEY=

# Optional rank lookup adapters. Leave blank unless the server has the adapter configured.
MCP_GAOKAO_RANK_ENDPOINT=
MCP_GAOKAO_UVX_COMMAND=
UVX_COMMAND=

# Optional lifefloating/gaokao-vault PostgreSQL data source.
# Example: postgresql://gaokao:gaokao@host.docker.internal:5432/gaokao_vault
GAOKAO_VAULT_DATABASE_URL=
GAOKAO_DB__DSN=
GAOKAO_VAULT_DATABASE_SSL=false

# Docker host binding. Keep 127.0.0.1 when using Nginx/BaoTa reverse proxy.
HOST_BIND=127.0.0.1
HOST_PORT=3020
